#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "${SCRIPT_PATH}" ]; do
  LINK_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
  SCRIPT_PATH="$(readlink "${SCRIPT_PATH}")"
  [[ "${SCRIPT_PATH}" != /* ]] && SCRIPT_PATH="${LINK_DIR}/${SCRIPT_PATH}"
done
REPO_DIR="$(cd "$(dirname "${SCRIPT_PATH}")/.." && pwd)"
VDC_ROOT="${VDC_ROOT:-${HOME}/.vdc-tools}"
ENV_FILE="${VDC_ROOT}/.env"
ENV_EXAMPLE="${REPO_DIR}/.env.example"

if [[ "${1:-}" == "--version" || "${1:-}" == "-V" ]]; then
  echo "vdc-setup $(cat "${REPO_DIR}/VERSION") (vdc-tools)"
  exit 0
fi

MCP_DIR="${VDC_ROOT}/mcp"
MCP_FILE="${MCP_DIR}/mcp.json"

# Escape value for use in sed replacement
sed_escape() {
  printf '%s' "$1" | sed 's/[|&\\/]/\\&/g'
}

# Mask token: show first 3 and last 4 chars
mask_token() {
  local t="$1"
  if [ ${#t} -le 7 ]; then
    echo "***"
  else
    echo "${t:0:3}...${t: -4}"
  fi
}

# Prompt with optional default value
# Usage: prompt_value "LABEL" "current_value"
# Sets REPLY to the entered or default value
prompt_value() {
  local label="$1"
  local default="${2:-}"
  if [ -n "${default}" ]; then
    printf "%s [%s]: " "${label}" "${default}"
  else
    printf "%s: " "${label}"
  fi
  read -r REPLY
  REPLY="${REPLY:-${default}}"
}

# Prompt for secret with optional masked default
prompt_secret() {
  local label="$1"
  local default="${2:-}"
  if [ -n "${default}" ]; then
    printf "%s [%s]: " "${label}" "$(mask_token "${default}")"
  else
    printf "%s: " "${label}"
  fi
  read -rs REPLY
  echo ""
  REPLY="${REPLY:-${default}}"
}

# Fetch models from upstream and let user pick one
# Usage: select_model "base_url" "token" "current_model" ["label"]
# Sets REPLY to selected model name
select_model() {
  local base_url="$1"
  local token="$2"
  local current="${3:-}"
  local label="${4:-DEFAULT_MODEL}"

  echo ""
  echo "Fetching models from ${base_url}..."

  local response
  if ! response="$(curl -sf --max-time 5 \
    -H "Authorization: Bearer ${token}" \
    "${base_url}/v1/models" 2>/dev/null)"; then
    echo "Could not fetch models from ${base_url}"
    prompt_value "${label} (enter manually)" "${current}"
    return
  fi

  # Parse model IDs — try jq first, fall back to python3
  local models
  if command -v jq >/dev/null 2>&1; then
    models="$(echo "${response}" | jq -r '.data[].id' 2>/dev/null)" || models=""
  elif command -v python3 >/dev/null 2>&1; then
    models="$(echo "${response}" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for m in data.get('data', []):
    print(m['id'])
" 2>/dev/null)" || models=""
  else
    models=""
  fi

  if [ -z "${models}" ]; then
    echo "No models found in response."
    prompt_value "${label} (enter manually)" "${current}"
    return
  fi

  echo ""
  echo "Available models:"
  local i=1
  local model_array=()
  while IFS= read -r m; do
    model_array+=("${m}")
    echo "  ${i}) ${m}"
    i=$((i + 1))
  done <<< "${models}"

  echo ""
  if [ -n "${current}" ]; then
    printf "%s [%s]: " "${label}" "${current}"
  else
    printf "%s: " "${label}"
  fi
  read -r REPLY

  if [ -z "${REPLY}" ]; then
    REPLY="${current}"
  elif [[ "${REPLY}" =~ ^[0-9]+$ ]] && [ "${REPLY}" -ge 1 ] && [ "${REPLY}" -le "${#model_array[@]}" ]; then
    REPLY="${model_array[$((REPLY - 1))]}"
  fi
  # else: user typed a model name directly, keep REPLY as-is
}

# --- Subcommand: figma ---
setup_figma() {
  echo ""
  echo "=== Figma MCP configuration ==="
  echo ""

  mkdir -p "${MCP_DIR}"

  # Read current key if mcp.json exists
  local current_key=""
  if [ -f "${MCP_FILE}" ]; then
    if command -v jq >/dev/null 2>&1; then
      current_key="$(jq -r '.mcpServers.figma.env.FIGMA_API_KEY // ""' "${MCP_FILE}" 2>/dev/null)" || current_key=""
    elif command -v python3 >/dev/null 2>&1; then
      current_key="$(python3 -c "
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    print(d.get('mcpServers',{}).get('figma',{}).get('env',{}).get('FIGMA_API_KEY',''))
except: print('')
" "${MCP_FILE}" 2>/dev/null)" || current_key=""
    fi
  fi

  echo "Get your token at: figma.com > Settings > Personal Access Tokens"
  echo ""
  prompt_secret "FIGMA_API_KEY" "${current_key}"
  local figma_key="${REPLY}"

  if [ -z "${figma_key}" ]; then
    echo "No key provided. Skipping Figma setup."
    return
  fi

  # Ensure mcp.json exists with base structure
  if [ ! -f "${MCP_FILE}" ]; then
    cp "${REPO_DIR}/examples/mcp.json.example" "${MCP_FILE}"
  fi

  # Update the Figma API key
  if command -v python3 >/dev/null 2>&1; then
    python3 -c "
import json, sys
path = sys.argv[1]
key = sys.argv[2]
with open(path, 'r') as f:
    data = json.load(f)
servers = data.setdefault('mcpServers', {})
figma = servers.setdefault('figma', {
    'type': 'stdio',
    'command': 'figma-developer-mcp',
    'args': ['--stdio'],
    'env': {}
})
figma.setdefault('env', {})['FIGMA_API_KEY'] = key
with open(path, 'w') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')
" "${MCP_FILE}" "${figma_key}"
  elif command -v jq >/dev/null 2>&1; then
    local tmp
    tmp="$(mktemp)"
    jq --arg key "${figma_key}" '.mcpServers.figma.env.FIGMA_API_KEY = $key' "${MCP_FILE}" > "${tmp}" && mv "${tmp}" "${MCP_FILE}"
  else
    echo "python3 or jq required to update mcp.json" >&2
    exit 1
  fi

  echo ""
  echo "Figma configured in ${MCP_FILE}"
  echo "Restart vdc-claude to apply."
}

# --- Subcommand: main (LLM backend) ---
setup_main() {
  echo ""
  echo "=== vdc-tools configuration ==="
  echo ""

  CURRENT_URL=""
  CURRENT_TOKEN=""
  CURRENT_MODEL=""
  CURRENT_SMALL_MODEL=""

  # Load existing values if editing
  if [ -f "${ENV_FILE}" ]; then
    echo "Editing existing configuration (${ENV_FILE})"
    echo "Press Enter to keep current value."
    echo ""
    CURRENT_URL="$(grep -m1 '^UPSTREAM_BASE_URL=' "${ENV_FILE}" | cut -d= -f2- || true)"
    CURRENT_TOKEN="$(grep -m1 '^UPSTREAM_TOKEN=' "${ENV_FILE}" | cut -d= -f2- || true)"
    CURRENT_MODEL="$(grep -m1 '^DEFAULT_MODEL=' "${ENV_FILE}" | cut -d= -f2- || true)"
    CURRENT_SMALL_MODEL="$(grep -m1 '^SMALL_FAST_MODEL=' "${ENV_FILE}" | cut -d= -f2- || true)"
  else
    echo "First-time setup."
    echo ""
  fi

  prompt_value "UPSTREAM_BASE_URL" "${CURRENT_URL}"
  NEW_URL="${REPLY}"

  prompt_secret "UPSTREAM_TOKEN" "${CURRENT_TOKEN}"
  NEW_TOKEN="${REPLY}"

  select_model "${NEW_URL}" "${NEW_TOKEN}" "${CURRENT_MODEL}" "DEFAULT_MODEL"
  NEW_MODEL="${REPLY}"

  select_model "${NEW_URL}" "${NEW_TOKEN}" "${CURRENT_SMALL_MODEL}" "SMALL_FAST_MODEL"
  NEW_SMALL_MODEL="${REPLY}"

  # Write .env
  if [ -f "${ENV_FILE}" ]; then
    # Edit mode: update values in existing file
    sed -i.bak \
      -e "s|^UPSTREAM_BASE_URL=.*|UPSTREAM_BASE_URL=$(sed_escape "${NEW_URL}")|" \
      -e "s|^UPSTREAM_TOKEN=.*|UPSTREAM_TOKEN=$(sed_escape "${NEW_TOKEN}")|" \
      -e "s|^DEFAULT_MODEL=.*|DEFAULT_MODEL=$(sed_escape "${NEW_MODEL}")|" \
      "${ENV_FILE}"
    # SMALL_FAST_MODEL may not exist in older .env files — append if missing
    if grep -q '^SMALL_FAST_MODEL=' "${ENV_FILE}"; then
      sed -i.bak -e "s|^SMALL_FAST_MODEL=.*|SMALL_FAST_MODEL=$(sed_escape "${NEW_SMALL_MODEL}")|" "${ENV_FILE}"
      rm -f "${ENV_FILE}.bak"
    else
      echo "SMALL_FAST_MODEL=${NEW_SMALL_MODEL}" >> "${ENV_FILE}"
    fi
    rm -f "${ENV_FILE}.bak"
  else
    # First-time: generate from template
    if [ ! -f "${ENV_EXAMPLE}" ]; then
      echo "Template not found: ${ENV_EXAMPLE}" >&2
      exit 1
    fi
    mkdir -p "$(dirname "${ENV_FILE}")"
    sed \
      -e "s|^UPSTREAM_BASE_URL=.*|UPSTREAM_BASE_URL=$(sed_escape "${NEW_URL}")|" \
      -e "s|^UPSTREAM_TOKEN=.*|UPSTREAM_TOKEN=$(sed_escape "${NEW_TOKEN}")|" \
      -e "s|^DEFAULT_MODEL=.*|DEFAULT_MODEL=$(sed_escape "${NEW_MODEL}")|" \
      -e "s|^SMALL_FAST_MODEL=.*|SMALL_FAST_MODEL=$(sed_escape "${NEW_SMALL_MODEL}")|" \
      "${ENV_EXAMPLE}" > "${ENV_FILE}"
  fi

  echo ""
  echo "Configuration saved to ${ENV_FILE}"
}

# --- Route subcommand ---
case "${1:-}" in
  figma)
    setup_figma
    ;;
  *)
    setup_main
    ;;
esac
