# LiteLLM / gateway upstream.
# Remote example:
# UPSTREAM_BASE_URL=https://your-remote-litellm.example.com
# Local LiteLLM example from Docker on macOS:
# UPSTREAM_BASE_URL=http://host.docker.internal:4000
UPSTREAM_BASE_URL=https://your-remote-litellm.example.com
# Match the LiteLLM master key. For a local test setup you can use: ollama
UPSTREAM_TOKEN=sk-your-upstream-token

# Internal proxy port inside docker network
PROXY_PORT=8080

# Local proxy sanitization
STRIP_CONTEXT_MANAGEMENT=true
STRIP_THINKING=false
STRIP_MCP_SERVERS=false
STRIP_CONTAINER_FIELD=false

# Optional upstream response tuning.
# For local Ollama + qwen3, setting 256 can reduce long thinking loops.
MAX_TOKENS_CAP=

# Upstream request timeout
REQUEST_TIMEOUT_MS=300000

# Default model when --model is not specified
DEFAULT_MODEL=

# Proxy logging: silent|info|debug
LOG_LEVEL=info

# This token is only used between Claude Code and the local proxy.
# It does not need to match the upstream token.
CLAUDE_GATEWAY_TOKEN=dummy
